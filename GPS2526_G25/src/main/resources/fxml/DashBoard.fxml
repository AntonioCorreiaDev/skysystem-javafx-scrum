<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane styleClass="root-container" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pt.isec.skysystem.view.pages.DashBoardView">
    <top>
        <HBox alignment="CENTER_RIGHT" prefWidth="720.0" spacing="10.0">
            <children>
                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="backButton" onAction="#handleBackButton" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" opacity="0.6" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/icons/arrow.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Voltar à Home" />
                    </tooltip>
                </Button>

            </children>
            <padding>
                <Insets right="20" top="10"/>
            </padding>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-background-color: linear-gradient(to bottom, #72CCD6,#DFF0F7 );">

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="30" style="-fx-background-color: transparent;">
                        <padding>
                            <Insets bottom="30" left="60" right="60" top="30" />
                        </padding>

                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <ImageView fx:id="welcomeIcon" fitHeight="32" fitWidth="32" preserveRatio="true">
                                    <image>
                                        <Image url="@../images/icons/waving.png" />
                                    </image>
                                </ImageView>
                                <Label fx:id="welcomeLabel" text="WELCOME BACK!" textFill="#00333e">
                                    <font>
                                        <Font name="System Bold" size="28" />
                                    </font>
                                </Label>
                            </HBox>
                            <Label fx:id="overviewLabel" text="Here's an overview of your travel plans and personalized recommendations" textFill="#00333e">
                                <font>
                                    <Font size="15" />
                                </font>
                            </Label>
                        </VBox>

                        <VBox spacing="15">
                            <Label text="Favourite Destinations" textFill="#00333e">
                                <font>
                                    <Font name="System Bold" size="20" />
                                </font>
                            </Label>

                            <FlowPane fx:id="upcomingTripsContainer" hgap="20" styleClass="upcoming-trips-container" vgap="20">
                            </FlowPane>
                        </VBox>

                        <VBox spacing="15">
                            <Label text="Upcoming Flights" textFill="#00333e">
                                <font>
                                    <Font name="System Bold" size="20" />
                                </font>
                            </Label>

                            <VBox fx:id="recommendedContainer" spacing="15" styleClass="recommended-container">
                            </VBox>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
