<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane minWidth="400.0" prefHeight="135.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 5; -fx-border-color: #72CCD6; -fx-border-radius: 5;" stylesheets="@../css/ai_suggestions.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pt.isec.skysystem.model.data.Controllers.SuggestionController">
    <effect>
        <DropShadow height="10.0" radius="4.5" width="10.0">
            <color>
                <Color red="0.0" green="0.0" blue="0.0" opacity="0.1" />
            </color>
        </DropShadow>
    </effect>
    <children>
        <HBox spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <ImageView fx:id="cardImage" fitHeight="133.0" fitWidth="133.0" pickOnBounds="true" preserveRatio="false">
                </ImageView>

                <AnchorPane HBox.hgrow="ALWAYS">
                    <children>
                        <AnchorPane prefHeight="35.0" style="-fx-background-color: #D3E8EB; -fx-background-radius: 0 5 0 0;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <children>
                                <Label fx:id="cardDestination" layoutX="14.0" layoutY="9.0" style="-fx-text-fill: #202B55;" text="A carregar destino..." AnchorPane.leftAnchor="14.0" >
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

                                <HBox alignment="CENTER_RIGHT" spacing="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0" AnchorPane.bottomAnchor="5.0">
                                    <children>
                                        <Button fx:id="viewCardButton" mnemonicParsing="false" onAction="#handleSearchCardButton" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                            <graphic>
                                                <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.7" pickOnBounds="true" preserveRatio="true">
                                                    <image>
                                                        <Image url="@../images/icons/aviao.png" />
                                                    </image>
                                                </ImageView>
                                            </graphic>
                                        </Button>

                                        <Button fx:id="favouriteCardButton" mnemonicParsing="false" onAction="#handleFavouriteCardButton" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                            <graphic>
                                                <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.7" pickOnBounds="true" preserveRatio="true">
                                                    <image>
                                                        <Image url="@../images/icons/heart.png" />
                                                    </image>
                                                </ImageView>
                                            </graphic>
                                        </Button>

                                        <Button fx:id="refreshCardButton" mnemonicParsing="false" onAction="#handleRefreshCardButton" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                            <graphic>
                                                <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.7" pickOnBounds="true" preserveRatio="true">
                                                    <image>
                                                        <Image url="@../images/icons/refresh.png" />
                                                    </image>
                                                </ImageView>
                                            </graphic>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>

                        <Label fx:id="cardReason" style="-fx-text-fill: #333333;" text="A carregar a razão pela qual deve visitar este local..." wrapText="true" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="45.0">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>

                        <Label fx:id="cardTags" style="-fx-text-fill: #555555; -fx-font-style: italic;" text="Tags" wrapText="true" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="120.0">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label fx:id="cardPrice" style="-fx-text-fill: #202B55;" text="--- €" AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="14.0">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
            </children>
        </HBox>
    </children>
</AnchorPane>