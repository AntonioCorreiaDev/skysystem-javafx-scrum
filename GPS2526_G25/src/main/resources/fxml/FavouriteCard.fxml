<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane"
           maxHeight="-Infinity" maxWidth="-Infinity"
           minHeight="-Infinity" minWidth="-Infinity"
           prefWidth="180.0"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="pt.isec.skysystem.view.pages.SuggestionCardController">

    <VBox fx:id="cardVBox" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <ImageView fx:id="image" fitHeight="140.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="false" style="-fx-background-radius: 15 15 0 0;" />

        <VBox alignment="CENTER_LEFT" spacing="2.0">
            <padding>
                <Insets left="10.0" right="10.0" top="5.0" bottom="5.0" />
            </padding>
            <children>
                <Label fx:id="destinationLabel" text="Destination"
                       textFill="#484848"
                       wrapText="true"
                       maxWidth="160.0"
                       style="-fx-text-fill: #484848;">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
            </children>
        </VBox>
        
        <!-- Expandable Details Section (Initially Hidden) -->
        <VBox fx:id="expandedDetailsSection" managed="false" visible="false" spacing="4.0" style="-fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets left="10.0" right="10.0" top="8.0" bottom="8.0" />
            </padding>
            <children>
                <Label fx:id="reasonLabel" text="Description will appear here" 
                       wrapText="true" 
                       style="-fx-text-fill: #2C2C2C; -fx-font-size: 11px;" 
                       maxWidth="160.0" />
                
                <Label fx:id="priceLabel" text="€€€" 
                       style="-fx-text-fill: #1A4D54; -fx-font-size: 11px; -fx-font-weight: bold;" />
            </children>
        </VBox>
    </VBox>

    <Button fx:id="removeButton" mnemonicParsing="false" onAction="#handleRemoveAction"
            text="✕" textFill="WHITE"
            StackPane.alignment="TOP_RIGHT">
        <StackPane.margin>
            <Insets right="8.0" top="8.0" />
        </StackPane.margin>
        <font>
            <Font name="System Bold" size="12.0" />
        </font>
        <style>
            -fx-background-color: rgba(0, 0, 0, 0.5);
            -fx-background-radius: 50;
            -fx-min-width: 25px;
            -fx-min-height: 25px;
            -fx-padding: 0;
            -fx-cursor: hand;
        </style>
    </Button>

</StackPane>